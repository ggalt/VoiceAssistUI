[Unit]
Description=Squeezelite Player
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/home/alarm/projects/squeezelite/squeezelite -s 192.168.1.10 -n "MasterBath" -o plughw:CARD=seeed2micvoicec,DEV=0
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
